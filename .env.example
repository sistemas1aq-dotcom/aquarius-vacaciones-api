# ============================================================================
# AQUARIUS - Variables de entorno del backend
# Copia este archivo como .env y ajusta los valores.
# ============================================================================

# ─── Base de datos PostgreSQL ──────────────────────────────────────
# Opción A: URL completa (recomendado para Supabase / Neon / Vercel Postgres)
# DATABASE_URL=postgresql://usuario:password@host:5432/aquarius_vacaciones?sslmode=require

# Opción B: variables individuales (para Postgres local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aquarius_vacaciones
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSLMODE=prefer

# ─── App ───────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
APP_CORS_ORIGINS=http://localhost:4200,http://localhost

# ─── Email SMTP (opcional, para recordatorios) ─────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=RRHH Aquarius
SMTP_FROM_EMAIL=rrhh@aquarius.com.pe

# ─── Recordatorios ─────────────────────────────────────────────────
REMINDER_THRESHOLD_DAYS=30
REMINDER_CRON_HOUR=8
REMINDER_CRON_MINUTE=0

# Desactivar scheduler en entornos serverless (Vercel). True en local.
ENABLE_SCHEDULER=true

# ─── JWT (autenticación) ───────────────────────────────────────────
# En producción, genera un secret largo y aleatorio:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE-ME-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
